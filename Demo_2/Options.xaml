    <ResourceDictionary
    x:Class="Sd.NINA.Demo2.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary">
    <!--  This data template will be displayed in N.I.N.A. on the options->plugin tab with the datacontext of the TestPlugin instance  -->
    <!--  In order for this datatemplate to be picked correctly, the key has to follow the naming convention of <IPlugin.Name>_Options -->
    <!--  Furthermore the Resource Dictionary has to be exported via code behind export attributes  -->
    <DataTemplate x:Key="GRB_Helper_Options">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Separator ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="General Settings"/>

            <!-- ── Observatory Constraints ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="Observatory Constraints"/>

            <!-- ── Declination ───────────────────────────────────────────────────── -->
            <TextBlock 
                Grid.Row="4"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Dec between" />
            <StackPanel
                Grid.Row="4"
                Grid.Column="1"
                Margin="10,0,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Left">
            <ninactrl:UnitTextBox 
                Margin="0,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding DecMin}"
                Unit="deg" />
            <TextBlock 
                VerticalAlignment="Center"
                Text=" and " />
            <ninactrl:UnitTextBox 
                Margin="0,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding DecMax}"
                Unit="deg" />
            </StackPanel>

            <!-- ── Localization Uncertainty ───────────────────────────────────────────────────── -->
            <TextBlock 
                Grid.Row="5"
                Grid.Column="0"            
                VerticalAlignment="Center"
                Text="Max. localization Uncertainty" />
            <ninactrl:UnitTextBox 
                Grid.Row="5"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding MaxLocalUncertainty}"
                ToolTip="Maximum allowed position uncertainty. Targets exceeding this value will be skipped."
                Unit="arcmins" />

            <!-- ── Observatory Code ───────────────────────────────────────────────────── -->
            <TextBlock 
                Grid.Row="2"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Observatory Code" />
            <TextBox 
                Grid.Row="2"
                Grid.Column="1"
                HorizontalAlignment="Left"
                Width="70"
                Margin="10,5,0,0"
                ToolTip="Observatory code assigned by MPC. If left empty, Site longitude, latitude and elevation from N.I.N.A. configuration, will be used."
                Text="{Binding ObservatoryCode}" />

            <TextBlock 
                Grid.Row="6"             
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="GRB Age less than "/>
            <ninactrl:UnitTextBox 
                Grid.Row="6"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding GRB_age}"
                ToolTip="Maximum allowed time since the GRB trigger (in hours). Older events will be ignored."
                Unit="hours" />

            <TextBlock 
                Grid.Row="9"             
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Count Rate greater than"/>
            <ninactrl:UnitTextBox 
                Grid.Row="9"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding CountRate}"
                ToolTip="Filters time bins where the background-subtracted count rate exceeds the selected threshold (counts/s)."
                Unit="counts/sec" />
            <TextBlock
                Grid.Row="9"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="(if not available ignore this parameter)"/>
            
            <TextBlock 
                Grid.Row="10"             
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Flux greater than (erg/cm²/s)"/>
            <StackPanel
                Grid.Row="10"
                Grid.Column="1"
                Margin="10,0,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Left">
            <ninactrl:UnitTextBox 
                Margin="0,5,0,0"
                Text="{Binding Flux_1}"
                ToolTip="Filters intervals where the energy flux (erg/cm²/s) exceeds the selected threshold."
                Unit="" />
                <TextBlock 
                VerticalAlignment="Center"
                Text=" e " />
                <ninactrl:UnitTextBox 
                Margin="0,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding Flux_2}"
                ToolTip="Filters intervals where the energy flux (erg/cm²/s) exceeds the selected threshold."
                Unit="erg/cm²/s" />
            </StackPanel>
            <TextBlock
                Grid.Row="10"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="(if not available ignore this parameter)"/>
                

            <TextBlock 
                Grid.Row="11"             
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="SNR greater than"/>
            <ninactrl:UnitTextBox 
                Grid.Row="11"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding SNR}"
                ToolTip="Filters intervals where the signal-to-noise ratio (SNR) exceeds the selected threshold, highlighting statistically significant emission."
                Unit="" />
            <TextBlock
                Grid.Row="11"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="(if not available ignore this parameter)"/>
            
            <TextBlock
                Grid.Row="7"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Minimum Altitude"/>
            <ninactrl:UnitTextBox 
                Grid.Row="7"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding Altitude}"
                ToolTip="Minimum altitude (in degrees) the target must reach above the horizon to be considered observable."
                Unit="° " />
            <!-- We need to confirm magnitude & change observibility code
            Insiyah: I thought the higher the magnitude the brighter the object however it turns out to be the opposite -->
            <TextBlock
                Grid.Row="8"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Maximum Magnitude"/>
            <ninactrl:UnitTextBox 
                Grid.Row="8"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding Mag}"
                ToolTip=" "
                Unit="" />
            
            <TextBlock 
                Grid.Row="1"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Profile Selected" />
            <ComboBox
                Grid.Row="1"
                Grid.Column="1"                
                Height="25"
                MinWidth="70"
                Margin="10,5,0,0"
                IsEditable="False"
                IsTextSearchEnabled="False"
                ToolTip="Select which NINA profile to use. The profile determines the observer location, equipment, and other settings used by this plugin."
                ItemsSource="{Binding AvailableProfiles}"
                SelectedValue="{Binding SelectedProfile}">
            </ComboBox>
            
            <TextBlock
                Grid.Row="12"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Space Telescope"/>
            <StackPanel
                Grid.Row="12"
                Grid.Column="1"
                Margin="10,0,0,0"
                Orientation="Horizontal"
                HorizontalAlignment="Left">
                <CheckBox Content="SWIFT"
                          IsChecked="{Binding isSwift}"
                          Style="{x:Null}"/>
                <CheckBox Content="EP"
                         IsChecked="{Binding isEP}"
                         Style="{x:Null}"/>
                <CheckBox Content="SVOM"
                          IsChecked="{Binding isSVOM}"
                          Style="{x:Null}"/>
                <CheckBox Content="Fermi"
                          IsChecked="{Binding isFermi}"
                          Style="{x:Null}"/>
                <CheckBox Content="Other"
                          IsChecked="{Binding isOther}"
                          Style="{x:Null}"/>
            </StackPanel>

            <!-- ── Separator ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="13"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="Capture Settings"/>

            <!-- B: Exposure count -->
            <TextBlock
                Grid.Row="14"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Exposure Count"/>
            <ninactrl:UnitTextBox
                Grid.Row="14"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding ExposureCount}"
                ToolTip="Number of LIGHT frames to capture per GRB event."
                Unit="frames"/>

            <!-- B: Exposure time -->
            <TextBlock
                Grid.Row="15"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Exposure Time"/>
            <ninactrl:UnitTextBox
                Grid.Row="15"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding ExposureTime}"
                ToolTip="Duration of each LIGHT frame."
                Unit="s"/>

            <!-- B: Binning -->
            <TextBlock
                Grid.Row="16"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Binning"/>
            <ninactrl:UnitTextBox
                Grid.Row="16"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding Binning}"
                ToolTip="Camera binning mode (1 = 1×1, 2 = 2×2, etc.)."
                Unit="×"/>

            <!-- ── Separator ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="18"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="Sky Constraints"/>

            <!-- C: Twilight -->
            <TextBlock
                Grid.Row="19"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Twilight (Sun alt &lt;)"/>
            <ninactrl:UnitTextBox
                Grid.Row="19"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding AstroTwilight}"
                ToolTip="Maximum Sun altitude for darkness (e.g. -6 = civil, -12 = nautical, -18 = astronomical)."
                Unit="°"/>

            <!-- C: Moon altitude -->
            <TextBlock
                Grid.Row="20"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Max Moon Altitude"/>
            <ninactrl:UnitTextBox
                Grid.Row="29"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding MaxMoonAlt}"
                ToolTip="Reject observations when the Moon is above this altitude."
                Unit="°"/>

            <!-- C: Moon separation -->
            <TextBlock
                Grid.Row="21"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Min Moon Separation"/>
            <ninactrl:UnitTextBox
                Grid.Row="21"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding MinMoonSep}"
                ToolTip="Minimum angular distance between the Moon and the GRB target."
                Unit="°"/>

            <!-- C: Moon phase -->
            <TextBlock
                Grid.Row="22"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Max Moon Phase"/>
            <ninactrl:UnitTextBox
                Grid.Row="22"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding MaxMoonPhase}"
                ToolTip="Maximum lunar illumination (%). Observations are skipped when the Moon is brighter than this."
                Unit="%"/>

            <!-- ── Separator ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="23"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="Post-Capture"/>

            <TextBlock
                Grid.Row="24"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Siril Executable Path"/>
            <TextBox
                Grid.Row="24"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="10,5,0,0"
                Width="300"
                HorizontalAlignment="Left"
                ToolTip="Full path to siril.exe. Leave empty to disable auto-open."
                Text="{Binding SirilPath}"/>

            <!-- ── Separator ───────────────────────────────────────────────────── -->
            <TextBlock
                Grid.Row="25"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Margin="0,10,0,4"
                FontWeight="Bold"
                Text="Observatory State"/>

            <!-- Max camera wait threshold -->
            <TextBlock
                Grid.Row="26"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Max Camera Wait"/>
            <ninactrl:UnitTextBox
                Grid.Row="26"
                Grid.Column="1"
                Margin="10,5,0,0"
                HorizontalAlignment="Left"
                Text="{Binding MaxWaitMinutes}"
                ToolTip="If the camera is exposing when a GRB fires, wait this many minutes for it to finish. If it is still busy after this time, the current exposure is interrupted and the GRB is captured immediately."
                Unit="min"/>
            <TextBlock
                Grid.Row="26"
                Grid.Column="2"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Text="(0 = interrupt immediately)"/>

        </Grid> 
    </DataTemplate>
</ResourceDictionary>

